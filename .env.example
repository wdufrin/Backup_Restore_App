# --- App Mode & Feature Flags ---
VITE_ENABLE_ADMIN_MODE=false
VITE_SINGLE_CLICK_MIGRATION=true
VITE_IDP_CHANGE_ENABLED=true
VITE_ENABLE_GOOGLE_IDP=true
VITE_ENABLE_WIF_IDP=true
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Source Environment ---
VITE_SOURCE_PROJECT=your-source-gcp-project-id
VITE_SOURCE_LOCATION=global-or-regional-location
VITE_SOURCE_APP_ID=your-source-app-engine-id
VITE_BYPASS_OWNER_FILTER=false
VITE_ENABLE_AGENT_VIEW_FALLBACK=false
VITE_SOURCE_IDP=Google # Google or WiF

# --- Target Environment ---
VITE_TARGET_PROJECT=your-target-gcp-project-id
VITE_TARGET_LOCATION=global-or-regional-location
VITE_TARGET_APP_ID=your-target-app-engine-id
VITE_TARGET_APP_URL=https://vertexaisearch.cloud.google.com/home/cid/...
VITE_TARGET_IDP=Google # Google or WiF

# --- Workforce Identity Federation (WIF) / Entra ID Config ---
VITE_WIF_USER_PROJECT=your-wif-user-project-id
VITE_WIF_POOL_ID=your-workforce-pool-id
VITE_WIF_PROVIDER_ID=your-workforce-provider-id
VITE_WIF_CLIENT_ID=your-azure-entra-app-client-id
VITE_WIF_AUTH_ENDPOINT=https://login.microsoftonline.com/your-tenant-id/oauth2/v2.0/authorize
VITE_WIF_REDIRECT_URI=http://localhost:5173/

# --- Migration Settings ---
VITE_MIGRATE_AGENTS=true
VITE_MIGRATE_NOTEBOOKS=true

# --- Mappings ---
# JSON mappings for data stores and collections between environments
VITE_DATASTORE_MAPPING='{"source_datastore_id":"target_datastore_id"}'
VITE_COLLECTION_MAPPING='{"source_collection_id":"target_collection_id"}'
